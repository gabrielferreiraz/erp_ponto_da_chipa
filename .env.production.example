# ==============================================================================
# VARIÁVEIS DE AMBIENTE PARA PRODUÇÃO - PONTO DA CHIPA
# ==============================================================================
# Instruções: Copie este arquivo para .env.production no servidor e preencha.

# [BANCO DE DADOS]
# URL de conexão com o PostgreSQL (EasyPanel/Hostinger)
# Ex: postgresql://user:password@host:5432/dbname?schema=public
DATABASE_URL="postgresql://postgres:senha_segura@postgres:5432/db-pontodachipa"

# [AUTENTICAÇÃO]
# Uma secret de 32+ caracteres. Gere com: openssl rand -base64 32
AUTH_SECRET="sua_secret_gerada_aqui"

# URL base do sistema para o NextAuth (SSL obrigatório em produção)
# Ex: https://ponto.seudominio.com
AUTH_URL="https://ponto.seudominio.com"

# [APLICAÇÃO]
# URL pública necessária para o cliente SSE (Server-Sent Events)
# Deve ser igual ao AUTH_URL
NEXT_PUBLIC_APP_URL="https://ponto.seudominio.com"

# Porta do container (padrão 3000)
PORT=3000

# Telemetria do Next.js (Desativada)
NEXT_TELEMETRY_DISABLED=1
NODE_ENV=production
