# Banco de dados PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/db-pontodachipa?schema=public"

# NextAuth — gere com: openssl rand -base64 32
NEXTAUTH_SECRET="SUBSTITUA_POR_SECRET_GERADO_COM_OPENSSL"

# URL da aplicação (sem barra final)
# Desenvolvimento: http://localhost:3000
# Produção: https://seu-dominio.com
NEXTAUTH_URL="http://localhost:3000"
